# Copy to .env in this folder (backend/) and fill in your key.
# Never commit .env.

GEMINI_API_KEY=

# Required for chat: model id only from env (no default in code). After GEMINI_API_KEY is set,
# run GET /api/gemini/models and copy an `id` value here.
GEMINI_MODEL=

# Optional (defaults shown in server)
# Stop Gemini calls before Vercel/serverless max duration (ms). Default 45000.
# GEMINI_REQUEST_TIMEOUT_MS=45000

# PORT=3001
# Comma-separated CORS origins (your frontend URL(s)). Required for cross-origin dev/production.
# Must match the browser tab origin exactly (scheme + host + port). Include preview URLs if you test them.
# CLIENT_ORIGIN=http://localhost:5173
# CLIENT_ORIGIN=http://localhost:5173,https://your-app.vercel.app,https://your-app-git-branch.vercel.app

# Set to 0 to disable per-request [express] logs (api/index always logs [api] lines).
# LOG_REQUESTS=0

# Per-client limit on POST /api/chat (protects Gemini quota)
# CHAT_RATE_LIMIT_MAX=3
# CHAT_RATE_LIMIT_WINDOW_MS=60000

# Behind a reverse proxy, set to 1 so req.ip uses X-Forwarded-For
# TRUST_PROXY=1
